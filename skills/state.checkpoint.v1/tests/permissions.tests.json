    },
    {
      "id": "PERM-013",
      "tool": "checkpoint.create",
      "mode": "write",
      "path": "secrets/token",
      "expected": "DENY",
      "reason": "PATH_NOT_ALLOWED"
    },
    {
      "id": "PERM-014",
      "tool": "unknown.tool",
      "mode": "read",
      "path": "state/checkpoints/a",
      "expected": "DENY",
      "reason": "TOOL_NOT_ALLOWED"
    },
    {
      "id": "PERM-015",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "state/checkpoints/a",
      "task_id": "bad",
      "expected": "DENY",
      "reason": "EXECUTION_IDENTITY_INVALID"
    },
    {
      "id": "PERM-016",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "state/checkpoints/a",
      "attempt": 3,
      "expected": "DENY",
      "reason": "MAX_ATTEMPTS_EXCEEDED"
    }
