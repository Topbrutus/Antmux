{
  "suite_id": "state-checkpoint-permissions-v1",
  "expected_count": 16,
  "tests": [
    {
      "id": "PERM-001",
      "tool": "checkpoint.create",
      "mode": "write",
      "path": "state/checkpoints/a.json",
      "expected": "ALLOW",
      "reason": ""
    },
    {
      "id": "PERM-002",
      "tool": "checkpoint.verify",
      "mode": "read",
      "path": "state/checkpoints/a.json",
      "expected": "ALLOW",
      "reason": ""
    },
    {
      "id": "PERM-003",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "artifacts/output/review.json",
      "expected": "ALLOW",
      "reason": ""
    },
    {
      "id": "PERM-004",
      "tool": "checkpoint.rebuild_audit",
      "mode": "write",
      "path": "state/outbox/event.json",
      "expected": "ALLOW",
      "reason": ""
    },
    {
      "id": "PERM-005",
      "tool": "checkpoint.delete",
      "mode": "write",
      "path": "state/checkpoints/a.json",
      "expected": "DENY",
      "reason": "TOOL_NOT_ALLOWED"
    },
    {
      "id": "PERM-006",
      "tool": "filesystem.delete",
      "mode": "write",
      "path": "state/checkpoints/a.json",
      "expected": "DENY",
      "reason": "TOOL_NOT_ALLOWED"
    },
    {
      "id": "PERM-007",
      "tool": "github.push",
      "mode": "write",
      "path": "",
      "expected": "DENY",
      "reason": "TOOL_NOT_ALLOWED"
    },
    {
      "id": "PERM-008",
      "tool": "network.request",
      "mode": "network",
      "path": "https://example.com",
      "expected": "DENY",
      "reason": "NETWORK_NOT_ALLOWED"
    },
    {
      "id": "PERM-009",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "other/a.json",
      "expected": "DENY",
      "reason": "PATH_NOT_ALLOWED"
    },
    {
      "id": "PERM-010",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "state/checkpoints/../secrets/a",
      "expected": "DENY",
      "reason": "PATH_TRAVERSAL"
    },
    {
      "id": "PERM-011",
      "tool": "checkpoint.read",
      "mode": "read",
      "path": "C:/state/checkpoints/a",
      "expected": "DENY",
